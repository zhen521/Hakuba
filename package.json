{
	"name": "svelte-blog",
	"version": "0.0.2",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "vite dev",
		"generateData": "tsx .scripts/pre/index.ts",
		"build": "tsx .scripts/pre/index.ts && vite build && tsx .scripts/post/index.ts",
		"report": "tsx .scripts/pre/index.ts && vite build && tsx .scripts/post/index.ts",
		"preview": "vite preview",
		"prepare": "svelte-kit sync",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check --plugin-search-dir=. . && eslint .",
		"format": "prettier --write --plugin-search-dir=. ."
	},
	"devDependencies": {
		"@fortawesome/fontawesome-free": "^7.2.0",
		"@giscus/svelte": "^3.1.0",
		"@sveltejs/adapter-static": "^3.0.0",
		"@sveltejs/kit": "^2.18.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@types/eslint": "^9.6.1",
		"@types/node": "^25.6.0",
		"@types/prettier": "^2.7.3",
		"@types/rollup-plugin-visualizer": "^4.2.4",
		"@typescript-eslint/eslint-plugin": "^8.58.2",
		"@typescript-eslint/parser": "^8.58.2",
		"autoprefixer": "^10.5.0",
		"clsx": "^2.1.1",
		"dotenv": "^17.4.2",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"feed": "^5.2.0",
		"mdsvex": "^0.12.7",
		"node-fetch": "^3.3.2",
		"path-to-regexp": "^8.2.0",
		"postcss": "^8.5.9",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"rehype-add-classes": "^1.0.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-external-links": "^3.0.0",
		"rehype-slug": "^6.0.0",
		"rollup-plugin-visualizer": "^7.0.1",
		"svelte": "^5.55.4",
		"svelte-check": "^4.2.1",
		"svelte-preprocess": "^6.0.3",
		"svelte-sitemap": "^3.1.0",
		"tailwindcss": "^4.2.2",
		"tslib": "^2.8.1",
		"tsx": "^4.21.0",
		"typescript": "5.9.3",
		"vite": "^6.2.1",
		"yaml": "^2.7.1"
	},
	"type": "module"
}
